{
  "manifest_version": 3,
  "name": "chromevideo",
  "version": "1.0.2",
  "description": "Chrome浏览器插件 - chromevideo",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Video 下载器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "downloads",
    "cookies",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
